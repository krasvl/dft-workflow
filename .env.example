# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_SECURE=false
MINIO_BUCKET=dft-workflow

# Redis (Celery broker / result backend)
REDIS_URL=redis://redis:6379/0

# Batch training trigger — enqueue a training job after N completed DFT runs.
# For a quick local demo use a small value, e.g. TRAINING_BATCH_MIN_SAMPLES=3.
TRAINING_BATCH_MIN_SAMPLES=1000
TRAINING_BATCH_COUNTER_KEY=dft:completed_since_last_train

# Service URLs (used by client tools; services on the docker network reach
# each other by their compose service name).
DATA_SERVICE_URL=http://data-service:8000
DENSITY_SERVICE_URL=http://density-service:8000

# DFT backend: pyscf (real SCF) or mock (synthetic DM, tests only).
DFT_ENGINE=pyscf
DFT_DEFAULT_METHOD=rks
DFT_DEFAULT_BASIS=sto-3g
# Heavier basis for higher-quality runs, e.g. def2-svp:
# DFT_DEFAULT_BASIS=def2-svp
DFT_MAX_SCF_CYCLES=100

# Density-service in-memory model cache lifetime (seconds). After expiry the
# service rescans MinIO and reloads the version with the best metric
# (best_loss is preferred over train_loss; lower is better). 0 disables caching.
MODEL_CACHE_TTL_SEC=300

# Training backend: mace (real graph2mat + mace-torch + MSE) or mock
# (random checkpoint for tests / smoke).
TRAINING_ENGINE=mace

# Logging
LOG_LEVEL=INFO
